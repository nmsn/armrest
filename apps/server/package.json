{
  "name": "@armrest/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local --port 3001",
    "dev:sqlite": "wrangler dev --local --port 3001",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 execute armrest-db --local --file=./src/db/migrations/*.sql",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "cron:run": "wrangler dev --local --env cron"
  },
  "dependencies": {
    "@better-auth/core": "^1.5.6",
    "@better-auth/drizzle-adapter": "^1.5.6",
    "@hono/zod-validator": "^0.2.0",
    "better-auth": "^1.0.0",
    "drizzle-orm": "^0.30.0",
    "hono": "^4.0.0",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "@types/node": "^20.0.0",
    "drizzle-kit": "^0.20.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4",
    "wrangler": "^3.0.0"
  }
}
